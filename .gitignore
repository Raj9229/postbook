```gitignore
# Dependencies
node_modules/

# Environment variables
.env
.env.*
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Tailwind
dist/

# Misc
coverage/
*.pid
*.seed
*.pid.lock

# Runtime uploads (keep default avatar)
public/images/uploads/*
!public/images/uploads/default.jpeg
```
