<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Postbook | Upload photo</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/stylesheet/app.css">
</head>
<body>

    <div class="page-shell">
        <div class="app-frame">
            <div class="app-nav">
                <div class="brand">
                    <div class="brand-mark">P</div>
                    <div class="brand-copy">
                        <p class="eyebrow">Profile media</p>
                        <h1 class="title">Postbook</h1>
                        <p class="subtitle">Upload a fresh avatar for your profile.</p>
                    </div>
                </div>
                <div class="nav-actions">
                    <a href="/profile" class="nav-link">Back to profile</a>
                </div>
            </div>

            <section class="panel panel-pad stack panel-strong" style="max-width: 680px; margin: 0 auto;">
                <span class="section-label">Update photo</span>
                <h2 class="hero-title" style="font-size: clamp(1.8rem, 4vw, 3rem);">Choose a new profile image.</h2>
                <p class="hero-copy">A clear avatar gives your posts a more polished presence across the app.</p>

                <form action="/upload" method="POST" class="form-grid" enctype="multipart/form-data">
                    <input type="file" name="image" class="form-file">
                    <div class="split-actions">
                        <button type="submit" class="accent-btn">Upload image</button>
                        <a href="/profile" class="ghost-btn">Cancel</a>
                    </div>
                </form>
            </section>
        </div>
    </div>

</body>
</html>