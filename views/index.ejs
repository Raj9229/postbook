<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Postbook | Create account</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/stylesheet/app.css">
</head>
<body>

    <div class="page-shell">
        <div class="app-frame">
            <div class="app-nav">
                <div class="brand">
                    <div class="brand-mark">P</div>
                    <div class="brand-copy">
                        <p class="eyebrow">Social journal</p>
                        <h1 class="title">Postbook</h1>
                        <p class="subtitle">Build your profile and start posting.</p>
                    </div>
                </div>
                <div class="nav-actions">
                    <a href="/login" class="nav-link">Login</a>
                </div>
            </div>

            <div class="hero-grid">
                <section class="panel panel-pad stack">
                    <span class="section-label">Create account</span>
                    <h2 class="hero-title">Join Postbook and shape your feed.</h2>
                    <p class="hero-copy">Create a profile, share your first thoughts, and explore a calmer, more polished posting experience.</p>

                    <form action="/register" method="post" class="form-grid">
                        <input type="text" name="username" placeholder="Username" class="form-input">
                        <input type="text" name="name" placeholder="Full name" class="form-input">
                        <input type="number" name="age" placeholder="Age" class="form-input">
                        <input type="email" name="email" placeholder="Email address" class="form-input">
                        <input type="password" name="password" placeholder="Password" class="form-input">
                        <button type="submit" class="primary-btn">Create account</button>
                    </form>

                    <p class="muted-copy">Already have an account? <a href="/login" class="author">Login here</a></p>
                </section>

                <aside class="panel panel-pad stack panel-strong">
                    <span class="section-label">What you get</span>
                    <div class="metric-grid">
                        <div class="metric-card"><strong>Fast</strong><span>Simple onboarding and clean interactions.</span></div>
                        <div class="metric-card"><strong>Personal</strong><span>Profiles and posts feel more expressive.</span></div>
                        <div class="metric-card"><strong>Focused</strong><span>Less clutter, more room for content.</span></div>
                    </div>
                    <div class="content-card">
                        <p class="body">A sharper interface for browsing posts, updating your profile, and keeping the app name consistent across every screen.</p>
                    </div>
                </aside>
            </div>
        </div>
    </div>
    
</body>
</html>