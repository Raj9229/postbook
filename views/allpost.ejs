<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>allpost</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>
    <div class="w-full h-full bg-zinc-600 p-8">
        <div class="mb-4 flex justify-between items-center">
            <h1 class="text-2xl font-bold">All Posts</h1>
            <a href="/profile" class="bg-blue-500 text-white p-2 rounded-md hover:bg-blue-600">Back to Profile</a>
            
        </div>
        <div class="bg-red-500 p-4  rounded shadow space-y-4 flex justify-center items-center flex-col">
            <% posts.reverse().forEach(post => { %>
                <div class="rounded shadow w-3/5 bg-white p-4">
                    <p class="text-gray-700"><%= post.content %></p>
                    <div class="mt-2">
                        <p class="text-sm text-gray-500">Posted by: <span class="text-sm text-blue-500 font-bold"><%= post.user.username %></span></p>
                    </div>
                </div>
            <% }); %>
        </div>
    </div>
</body>
</html>