<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Postbook | Explore posts</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/stylesheet/app.css">
</head>
<body>
    <div class="page-shell">
        <div class="app-frame stack">
            <div class="app-nav">
                <div class="brand">
                    <div class="brand-mark">P</div>
                    <div class="brand-copy">
                        <p class="eyebrow">Public feed</p>
                        <h1 class="title">Postbook</h1>
                        <p class="subtitle">Browse what the community is sharing.</p>
                    </div>
                </div>
                <div class="nav-actions">
                    <a href="/profile" class="nav-link">Back to profile</a>
                </div>
            </div>

            <section class="panel panel-pad panel-strong stack">
                <div class="page-heading">
                    <div>
                        <span class="section-label">All posts</span>
                        <h2>Latest from Postbook</h2>
                    </div>
                </div>

                <div class="posts-grid">
                    <% if (posts.length === 0) { %>
                        <div class="empty-state">No posts yet. When people publish, they will appear here.</div>
                    <% } %>
                    <% posts.reverse().forEach(post => { %>
                        <article class="content-card">
                            <div class="meta">
                                <span class="author"><%= post.user.username %></span>
                                <span>Public post</span>
                            </div>
                            <p class="body"><%= post.content %></p>
                        </article>
                    <% }); %>
                </div>
            </section>
        </div>
    </div>
</body>
</html>