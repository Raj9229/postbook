<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Postbook | Profile</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/stylesheet/app.css">
</head>
<body>

    <div class="page-shell">
        <div class="app-frame stack">
            <div class="app-nav">
                <div class="brand">
                    <div class="brand-mark">P</div>
                    <div class="brand-copy">
                        <p class="eyebrow">Your space</p>
                        <h1 class="title">Postbook</h1>
                        <p class="subtitle">Profile, posts, and updates in one place.</p>
                    </div>
                </div>
                <div class="nav-actions">
                    <a href="/allpost" class="nav-link">Explore posts</a>
                    <a href="/logout" class="danger-btn">Logout</a>
                </div>
            </div>

            <div class="profile-layout">
                <section class="panel panel-pad stack">
                    <span class="section-label">Profile</span>
                    <div class="avatar">
                        <img src="/images/uploads/<%= user.profileImage || 'default.jpeg' %>" alt="Profile Image" onerror="this.onerror=null;this.src='/images/uploads/default.jpeg';">
                    </div>

                    <div class="profile-fields">
                        <div class="profile-field"><span>Username</span><strong><%= user.username %></strong></div>
                        <div class="profile-field"><span>Name</span><strong><%= user.name %></strong></div>
                        <div class="profile-field"><span>Age</span><strong><%= user.age %></strong></div>
                        <div class="profile-field"><span>Email</span><strong><%= user.email %></strong></div>
                    </div>

                    <div class="split-actions">
                        <a href="/upload" class="secondary-btn">Update photo</a>
                    </div>
                </section>

                <section class="panel panel-pad stack panel-strong">
                    <div class="page-heading">
                        <div>
                            <span class="section-label">New post</span>
                            <h2>Share something with Postbook</h2>
                        </div>
                    </div>
                    <form action="/post" method="POST" class="form-grid">
                        <textarea name="content" placeholder="Write your post..." class="form-textarea"></textarea>
                        <button type="submit" class="primary-btn">Create post</button>
                    </form>

                    <div class="page-heading" style="margin-top: 10px;">
                        <div>
                            <span class="section-label">Your posts</span>
                            <h2>Latest activity</h2>
                        </div>
                    </div>

                    <div class="posts-grid">
                        <% if (user.posts.length === 0) { %>
                            <div class="empty-state">No posts yet. Share your first update to fill this space.</div>
                        <% } %>
                        <% user.posts.reverse().forEach(post => { %>
                            <article class="content-card">
                                <div class="meta">
                                    <span class="author">@ <%= user.username %></span>
                                    <span><%= post.likes.length %> likes</span>
                                </div>
                                <p class="body"><%= post.content %></p>
                                <div class="split-actions" style="margin-top: 16px;">
                                    <a href="/like/<%= post._id %>" class="secondary-btn"><%= post.likes.indexOf(user._id) !== -1 ? "Unlike" : "Like" %></a>
                                    <a href="/edit/<%= post._id %>" class="ghost-btn">Edit</a>
                                </div>
                            </article>
                        <% }); %>
                    </div>
                </section>
            </div>
        </div>
    </div>

</body>
</html>