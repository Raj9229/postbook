<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>miniproject1</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>

    <div class="w-full min-h-screen bg-zinc-900">
        <div class="bg-gray-800 p-4 flex justify-between items-center">
            <h3 class="text-3xl font-bold text-white mb-5">Profile</h3>
            <a href="/logout" class="text-white bg-red-500 hover:bg-red-800 p-2 rounded-md">Logout</a>
        </div>
        <p class="text-white">Username: <%= user.username %></p>
        <p class="text-white">Name: <%= user.name %></p>
        <p class="text-white">Age: <%= user.age %></p>
        <p class="text-white">Email: <%= user.email %></p>

        <p class="text-gray-600 font-bold mb-5 text-sm">you can create a new post</p>

        <form action="/post" method="POST" class="flex flex-col gap-2">
            <textarea name="content" placeholder="Content" class=" resize-none w-1/3 p-2 rounded-md" ></textarea>
            <button type="submit" class="bg-blue-500 text-white w-1/3 p-2 rounded-md">Create Post</button>

        </form>

        <div class="posts  mt-10">
            <h3 class="text-gray-600 font-bold mb-5">your posts</h3>
            <div class="postcontainer">
                    <% user.posts.reverse().forEach(post => { %>
                        <div class="post bg-gray-700 p-4 mb-4 rounded-md w-1/3">
                            <p class="text-blue-500">@ <%= user.username %></p>
                            <p class="text-white mb-2"><%= post.content %></p>
                            <p class="text-gray-400 text-sm">Likes: <%= post.likes.length %></p>
                            <div class="flex gap-2">
                                <a href="/like/<%= post._id %>" class="bg-blue-500 p-1 rounded-md hover:bg-blue-600 text-white">
                                    <%= post.likes.indexOf(user._id) !== -1 ? "Unlike" : "Like" %>
                                </a>
                                <a href="/edit/<%= post._id %>" class="bg-gray-500 p-1 rounded-md hover:bg-gray-600 text-white ml-2">Edit</a>
                            </div>
                        </div>
                    <% }); %>
            </div>

        </div>

    </div>

</body>
</html>