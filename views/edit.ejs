<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>miniproject1</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body>

    <div class="w-full min-h-screen bg-zinc-900">
        <div class="bg-gray-800 p-4 flex justify-between items-center">
            <h3 class="text-3xl font-bold text-white mb-5">Profile</h3>
            <a href="/logout" class="text-white bg-red-500 hover:bg-red-800 p-2 rounded-md">Logout</a>
        </div>

        <p class="text-gray-600 font-bold mb-5 text-sm">edit post</p>

        <form action="/edit/<%= post._id %>" method="POST" class="flex flex-col gap-2">
            <textarea name="content" placeholder="Content" class=" resize-none w-1/3 p-2 rounded-md" ><%= post.content %></textarea>
            <button type="submit" class="bg-yellow-500 text-white w-1/3 p-2 rounded-md">Update Post</button>

        </form>

    </div>

</body>
</html>