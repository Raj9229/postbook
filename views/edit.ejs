<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Postbook | Edit post</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/stylesheet/app.css">
</head>
<body>

    <div class="page-shell">
        <div class="app-frame">
            <div class="app-nav">
                <div class="brand">
                    <div class="brand-mark">P</div>
                    <div class="brand-copy">
                        <p class="eyebrow">Post editor</p>
                        <h1 class="title">Postbook</h1>
                        <p class="subtitle">Refine your post before it goes live.</p>
                    </div>
                </div>
                <div class="nav-actions">
                    <a href="/profile" class="nav-link">Back to profile</a>
                    <a href="/logout" class="danger-btn">Logout</a>
                </div>
            </div>

            <section class="panel panel-pad stack panel-strong" style="max-width: 760px; margin: 0 auto;">
                <span class="section-label">Edit post</span>
                <h2 class="hero-title" style="font-size: clamp(1.8rem, 4vw, 3rem);">Update your message.</h2>
                <p class="hero-copy">Keep the content, improve the wording, and save the revised version.</p>

                <form action="/edit/<%= post._id %>" method="POST" class="form-grid">
                    <textarea name="content" placeholder="Content" class="form-textarea"><%= post.content %></textarea>
                    <div class="split-actions">
                        <button type="submit" class="accent-btn">Update post</button>
                        <a href="/profile" class="ghost-btn">Cancel</a>
                    </div>
                </form>
            </section>
        </div>
    </div>

</body>
</html>